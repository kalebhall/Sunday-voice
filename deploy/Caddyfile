# Sunday Voice reverse proxy (Caddy)
# Replace sundayvoice.example.org with your actual hostname.
sundayvoice.example.org {
    encode zstd gzip

    # WebSocket endpoints (operator ingest + listener fan-out)
    @ws path /ws/*
    reverse_proxy @ws localhost:8000

    # API
    @api path /api/*
    reverse_proxy @api localhost:8000

    # Static frontend build output served by FastAPI (or directly by Caddy)
    reverse_proxy localhost:8000
}

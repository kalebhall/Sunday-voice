# Sunday Voice – Caddy reverse proxy
# TLS is provisioned automatically by Caddy via Let's Encrypt.
# Set the DOMAIN environment variable before running caddy, or replace the
# placeholder below with the real hostname.
#
# Caddy serves the React SPA static assets directly from the filesystem
# (frontend/dist) so uvicorn handles only API and WebSocket traffic.

translate.thestand.app {
    encode zstd gzip

    # Security headers for all responses.
    header {
        # Prevent the page from being embedded in frames (clickjacking).
        X-Frame-Options "DENY"
        # Prevent MIME-type sniffing.
        X-Content-Type-Options "nosniff"
        # Limit referrer information to the origin only.
        Referrer-Policy "strict-origin-when-cross-origin"
        # Permissions policy: disable features the app does not use.
        Permissions-Policy "geolocation=(), camera=(), payment=()"
        # Content-Security-Policy.
        # - default-src: block everything not explicitly allowed.
        # - script-src: only same-origin scripts (no inline, no eval).
        # - style-src: same-origin + unsafe-inline (Vite injects inline styles).
        # - connect-src: API and WebSocket on same origin.
        # - media-src: same-origin (TTS audio).
        # - object-src, frame-ancestors: block entirely.
        Content-Security-Policy "default-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' wss:; media-src 'self'; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        # HSTS: trust the TLS cert for 1 year (enable once stable).
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        # Remove the Server header to reduce fingerprinting.
        -Server
    }

    # Block Prometheus scrape endpoint from the public internet.
    # Allow access from the loopback interface only (scrape from localhost).
    @metrics path /metrics
    respond @metrics "Forbidden" 403

    # WebSocket endpoints (operator audio ingest + listener text fan-out).
    handle /ws/* {
        reverse_proxy localhost:8000
    }

    # REST API.
    handle /api/* {
        reverse_proxy localhost:8000
    }

    # App health probes (liveness / readiness).
    handle /healthz {
        reverse_proxy localhost:8000
    }
    handle /readyz {
        reverse_proxy localhost:8000
    }

    # React SPA.  Serve pre-built static assets directly; fall back to
    # index.html for any path the client-side router owns.
    handle {
        root * /opt/sunday-voice/frontend/dist
        try_files {path} /index.html
        file_server {
            # Cache immutable hashed assets aggressively; let the browser
            # revalidate index.html on every request.
            precompressed br gzip
        }
    }
}


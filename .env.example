# Sunday Voice environment configuration
# Copy to .env and fill in values. Do not commit .env.

# --- Application ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info
# Comma-separated list of allowed origins for CORS (operator/listener UIs)
APP_CORS_ORIGINS=http://localhost:5173

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_MINUTES=60
JWT_REFRESH_TOKEN_TTL_DAYS=14

# Per (client, email) sliding window on /api/auth/login.
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://sundayvoice:sundayvoice@localhost:5432/sundayvoice

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Retention ---
CONTENT_RETENTION_HOURS=48

# --- Providers ---
# Whisper (OpenAI) transcription
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1

# Google Cloud Translation v3
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=
GOOGLE_TRANSLATE_LOCATION=global

# Google Cloud Text-to-Speech
TTS_ENABLED=true

# --- Cost controls ---
MONTHLY_BUDGET_USD=50
BUDGET_ALERT_THRESHOLD=0.8

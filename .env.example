# Sunday Voice environment configuration
# Copy to .env and fill in values. Do not commit .env.

# --- Application ---
# Public base URL used for join links and QR codes (no trailing slash).
APP_BASE_URL=http://localhost:8000
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info
# Comma-separated list of allowed origins for CORS (operator/listener UIs).
APP_CORS_ORIGINS=http://localhost:5173

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_MINUTES=60
JWT_REFRESH_TOKEN_TTL_DAYS=14

# Per (client, email) sliding window on /api/auth/login.
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://sundayvoice:sundayvoice@localhost:5432/sundayvoice

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Retention ---
# Hours to retain transcripts and translations before deletion.
CONTENT_RETENTION_HOURS=48
# How often the cleanup job runs (minutes).
RETENTION_CLEANUP_INTERVAL_MINUTES=15
RETENTION_CLEANUP_ENABLED=true

# --- Transcription (OpenAI Whisper) ---
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1
# Max simultaneous Whisper API calls across all sessions. Lower if you hit 429s.
WHISPER_MAX_CONCURRENT=5
# Flush audio buffer to Whisper after this many bytes (~2 s of Opus 128 kbps audio).
WHISPER_CHUNK_FLUSH_BYTES=32768

# --- Translation (Google Cloud Translation v2 Basic) ---
# Create an API key in Google Cloud Console with Cloud Translation API enabled.
# Free tier: 500,000 characters/month. $20 per 1M characters after that.
GOOGLE_TRANSLATE_API_KEY=

# --- Text-to-Speech (Google Cloud TTS) ---
TTS_ENABLED=true
TTS_AUDIO_ENCODING=MP3
# Optional per-language voice overrides: comma-separated "lang=voice" pairs.
# Example: TTS_VOICE_OVERRIDES=es=es-US-Wavenet-B,sm=sm-x-standard-A
TTS_VOICE_OVERRIDES=
TTS_CACHE_DIR=/tmp/sunday-voice-tts-cache

# --- Listener WebSocket ---
LISTENER_SCROLLBACK_LIMIT=50
LISTENER_HEARTBEAT_SECONDS=15
LISTENER_MAX_CONNECTIONS_PER_IP=10
LISTENER_MAX_CONNECTIONS_PER_SESSION=100

# --- Join endpoint rate limit (anonymous, per IP) ---
JOIN_RATE_LIMIT_MAX_ATTEMPTS=30
JOIN_RATE_LIMIT_WINDOW_SECONDS=60

# --- Operator audio cap ---
# Rolling per-minute byte cap per session (default 10 MB).
OPERATOR_AUDIO_MAX_BYTES_PER_MINUTE=10485760

# --- Cost controls ---
MONTHLY_BUDGET_USD=50
BUDGET_ALERT_THRESHOLD=0.8

# --- Admin seeding (scripts/seed_admin.py) ---
# Optional: set to skip the interactive password prompt when seeding the first
# admin account. Do not set this in production; use the interactive prompt.
# SUNDAY_VOICE_ADMIN_PASSWORD=

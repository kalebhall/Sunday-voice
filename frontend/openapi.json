    "/api/sessions/join/{code}": {
      "get": {
        "tags": [
          "sessions"
        ],
        "summary": "Join Session",
        "description": "Look up a session by join code or join slug. No auth required.\n\nReturns only the information a listener needs -- no write paths, no\ninternal IDs beyond the session UUID needed to open a WebSocket.",

    "/api/sessions/{session_id}/webrtc/offer": {
      "post": {
        "tags": [
          "webrtc"
        ],
        "summary": "Webrtc Offer",
        "description": "Exchange SDP offer/answer to establish a WebRTC audio connection.\n\nThe operator sends an SDP offer; the server creates a PeerConnection,\nsets the remote description, generates an answer, and returns it.  Once\nthe ICE connection is established the server decodes the incoming audio\ntrack, windows it into ~2-3 s PCM frames, re-encodes to WAV, and feeds\nthe standard transcription pipeline.",
        "operationId": "webrtc_offer_api_sessions__session_id__webrtc_offer_post",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "session_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Session Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SDPOffer"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SDPAnswer"
                }
              }
            }
          },
          "422": {
